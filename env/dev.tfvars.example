# Example only. Normally generated by tools/excel_to_tfvars.py

project_name   = "aks-store-demo"
environment    = "dev"
location       = "koreacentral"
location_short = "krc"
prefix         = "son01"

namespaces = {
  "pets" = {
    enabled = true
    name    = "pets"
  }
  "argocd" = {
    enabled = true
    name    = "argocd"
  }
  "jenkins" = {
    enabled = true
    name    = "jenkins"
  }
}

apps = {
  "order-service" = {
    enabled        = true
    app_type       = "backend"
    namespace      = "pets"
    image          = "ghcr.io/azure-samples/aks-store-demo/order-service:latest"
    container_port = 3000
    replicas       = 1
    service_type   = "ClusterIP"
    service_port   = 3000
  }

  "store-front" = {
    enabled        = true
    app_type       = "frontend"
    namespace      = "pets"
    image          = "ghcr.io/azure-samples/aks-store-demo/store-front:latest"
    container_port = 8080
    replicas       = 1
    service_type   = "LoadBalancer"
    service_port   = 80
  }
}

persistent_volume_claims = {
  "upload-data" = {
    enabled       = true
    namespace     = "pets"
    storage_class = "azurefile-csi"
    size          = "50Gi"
    access_modes  = ["ReadWriteMany"]
    mount_path    = "/app/upload"
  }
}

helm_releases = {
  "argocd" = {
    enabled      = true
    namespace    = "argocd"
    repository   = "https://argoproj.github.io/argo-helm"
    chart        = "argo-cd"
    service_type = "LoadBalancer"
  }

  "jenkins" = {
    enabled      = true
    namespace    = "jenkins"
    repository   = "https://charts.jenkins.io"
    chart        = "jenkins"
    service_type = "LoadBalancer"
  }
}
